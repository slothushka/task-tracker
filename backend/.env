# ── Server ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/task-tracker

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_EXPIRES_IN=7d

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
