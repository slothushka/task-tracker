# ── Server ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/task-tracker
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/task-tracker
MONGODB_URI=mongodb://localhost:27017/task-tracker

# ── JWT ─────────────────────────────────────────────────────────────────────
# Use a long random string (32+ chars). Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=8cd3d698924efb8ec8b5f00e2e30d204bce4f954ce1f6ba964397db16e6eab2b
JWT_EXPIRES_IN=7d

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password   # Uncomment if Redis requires auth

# ── Frontend ────────────────────────────────────────────────────────────────
# Allowed CORS origin for the Next.js frontend
FRONTEND_URL=http://localhost:3000
